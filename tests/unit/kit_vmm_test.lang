testRun("kit/vmm awaitLifecycle aliases lifecycle wait", \ -> {
    mockSupervisorEvent(\timeoutMs -> {
        { type: "vm_exit", vmId: "target", status: "crashed", reason: "limit_exceeded" }
    })

    evt = awaitLifecycle("target", 1000)
    assertEquals("vm_exit", evt.type)
    assertEquals("target", evt.vmId)

    mockSupervisorEventOff()
})
