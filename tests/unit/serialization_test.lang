import "lib/vmm" (serialize, deserialize)
import "lib/test" (testRun, assertEquals, assertNotEquals)

testRun("Complex data structures serialization", fun() -> {
    record = {
        name: "Test",
        value: 123,
        nested: {
            list: [1, 2, 3],
            map: %{"a" => 1, "b" => 2}
        },
        tuple: (1, "two", true),
        opt: Some(42),
        none: None,
        res: Ok("success"),
        err: Fail("failure")
    }

    // Test GOB serialization (default)
    print("Testing GOB serialization...")
    bytes_gob = serialize(record)
    assertEquals(Ok(record), deserialize(bytes_gob), "GOB serialization failed")

    // Test FDF serialization
    print("Testing FDF serialization...")
    bytes_fdf = serialize(record, "fdf")
    assertEquals(Ok(record), deserialize(bytes_fdf), "FDF serialization failed")

    // Test explicit GOB serialization
    print("Testing explicit GOB serialization...")
    bytes_gob_explicit = serialize(record, "gob")
    assertEquals(Ok(record), deserialize(bytes_gob_explicit), "Explicit GOB serialization failed")

    // Verify formats are different
    assertNotEquals(bytes_gob, bytes_fdf, "GOB and FDF formats should be different")
})

testRun("Large integer serialization", fun() -> {
    print("Testing large integer...")
    large_int = 9223372036854775807
    bytes_large_gob = serialize(large_int)
    assertEquals(Ok(large_int), deserialize(bytes_large_gob), "Large int GOB failed")

    bytes_large_fdf = serialize(large_int, "fdf")
    assertEquals(Ok(large_int), deserialize(bytes_large_fdf), "Large int FDF failed")
})

