testRun("Type serialization", fun() -> {
    print("Testing type information serialization (FDF)...")

    // Empty list inference
    list = [1, 2, 3]
    list_bytes = serialize(list, "fdf")
    list_res = deserialize(list_bytes)
    assertEquals(Ok(list), list_res, "List elements type preservation failed")
    
    match list_res {
        Ok(v) -> assertEquals(true, typeOf(v, List(Int)), "List(Int) type preservation failed")
        _ -> assertEquals(true, false, "unwrap failed")
    }

    // Map inference
    m = %{"a" => 1, "b" => 2}
    map_bytes = serialize(m, "fdf")
    map_res = deserialize(map_bytes)
    assertEquals(Ok(m), map_res, "Map key/value types preservation failed")

    match map_res {
        Ok(v) -> assertEquals(true, typeOf(v, Map(String, Int)), "Map(String, Int) type preservation failed")
        _ -> assertEquals(true, false, "unwrap failed")
    }
})