import "lib/vmm" (serialize, deserialize)
import "lib/test" (testRun, assertEquals, assertNotEquals)

testRun("Complex data structures serialization", fun() -> {
    record = {
        name: "Test",
        value: 123,
        nested: {
            list: [1, 2, 3],
            map: %{"a" => 1, "b" => 2}
        },
        tuple: (1, "two", true),
        opt: Some(42),
        none: None,
        res: Ok("success"),
        err: Fail("failure")
    }

    // Test default serialization (FDF)
    print("Testing default serialization...")
    bytes_default = serialize(record)
    assertEquals(Ok(record), deserialize(bytes_default), "Default serialization failed")

    // Test explicit FDF serialization
    print("Testing FDF serialization...")
    bytes_fdf = serialize(record, "fdf")
    assertEquals(Ok(record), deserialize(bytes_fdf), "FDF serialization failed")

    // Default should match explicit FDF
    assertEquals(bytes_default, bytes_fdf, "Default and explicit FDF should be identical")

    // Test explicit GOB serialization
    print("Testing explicit GOB serialization...")
    bytes_gob = serialize(record, "ephemeral")
    assertEquals(Ok(record), deserialize(bytes_gob), "Explicit GOB serialization failed")

    // Verify formats are different
    assertNotEquals(bytes_gob, bytes_fdf, "GOB and FDF formats should be different")
})

testRun("Large integer serialization", fun() -> {
    print("Testing large integer...")
    large_int = 9223372036854775807
    bytes_large = serialize(large_int)
    assertEquals(Ok(large_int), deserialize(bytes_large), "Large int default failed")

    bytes_large_ephemeral = serialize(large_int, "ephemeral")
    assertEquals(Ok(large_int), deserialize(bytes_large_ephemeral), "Large int ephemeral failed")
})

testRun("Float serialization", fun() -> {
    print("Testing float...")
    flt = 3.14159
    bytes_flt = serialize(flt)
    assertEquals(Ok(flt), deserialize(bytes_flt), "Float default failed")

    bytes_flt_ephemeral = serialize(flt, "ephemeral")
