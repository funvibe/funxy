import "lib/mailbox" (Importance)
import "lib/test" (testRun, assertEquals, assertOk, testSpawnVM, assertTrue)
import "lib/rpc" (callWait)
import "lib/vmm" (getState, stopVM, vmStats)
import "lib/time" (sleepMs)

testRun("mailbox basic send/receive via RPC inspection", \ -> {
    recvIdRes = testSpawnVM("./tests/e2e/mailbox_1_recv.lang", {
        name: "worker_recv",
        capabilities: ["lib/mailbox", "lib/rpc", "lib/vmm"]
    })
    assertOk(recvIdRes)

    sendIdRes = testSpawnVM("./tests/e2e/mailbox_1_send.lang", {
        name: "worker_send",
        capabilities: ["lib/mailbox", "lib/rpc"]
    })
    assertOk(sendIdRes)

    match recvIdRes {
        Ok(recvId) -> {
            match sendIdRes {
                Ok(sendId) -> {
                    res = callWait(sendId, "sendMsg", "worker_recv", 1000)
                    assertOk(res)

                    match res {
                        Ok(v) -> assertEquals("sent", v)
                        Fail(e) -> ()
                    }

                    sleepMs(500)

                    res2 = callWait(recvId, "getResult", [], 1000)
                    assertOk(res2)
                    match res2 {
                        Ok(v) -> assertEquals("correct", v)
                        Fail(e) -> ()
                    }
                }
                Fail(e) -> ()
            }
        }
        Fail(e) -> ()
    }
})

testRun("mailbox requestWait and reply", \ -> {
    responderIdRes = testSpawnVM("./tests/e2e/mailbox_2_responder.lang", {
        name: "worker_responder_2",
        capabilities: ["lib/mailbox", "lib/time", "lib/vmm"]
    })
    assertOk(responderIdRes)

    requesterIdRes = testSpawnVM("./tests/e2e/mailbox_2_requester.lang", {
        name: "worker_requester_2",
        capabilities: ["lib/mailbox", "lib/time", "lib/vmm"]
    })
    assertOk(requesterIdRes)

    sleepMs(1500) // Wait for them to interact

    match responderIdRes {
        Ok(respId) -> {
            // we use stopVM to gracefully kill it and get its state
            stateRes = stopVM(respId, Some({ saveState: true }))
            assertOk(stateRes)
            match stateRes {
                Ok(s) -> assertEquals("correct", s)
                Fail(e) -> ()
            }
        }
        Fail(e) -> ()
    }

    match requesterIdRes {
        Ok(reqId) -> {
            stateRes = stopVM(reqId, Some({ saveState: true }))
            assertOk(stateRes)
            match stateRes {
                Ok(s) -> assertEquals("correct", s)
                Fail(e) -> ()
            }
        }
        Fail(e) -> ()
    }
})

