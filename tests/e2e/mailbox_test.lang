testRun("mailbox metrics", \ -> {
    recvIdRes = testSpawnVM("./tests/e2e/mailbox_7_metrics_recv.lang", {
        name: "worker_metrics_recv",
        capabilities: ["lib/mailbox", "lib/time", "lib/vmm"],
        mailbox: { capacity: 5, dropOnFull: Warn, strategy: "dropOld" }
    })
    assertOk(recvIdRes)

    sendIdRes = testSpawnVM("./tests/e2e/mailbox_7_metrics_send.lang", {
        name: "worker_metrics_sender",
        capabilities: ["lib/mailbox", "lib/time", "lib/vmm"]
    })
    assertOk(sendIdRes)

    sleepMs(3000)

    match recvIdRes {
        Ok(recvId) -> {
            stats = vmStats(recvId)

            // Receiver successfully extracted messages (at least 2)
            match stats["mailbox_messages_received_total"] {
                Some(v) -> assertTrue(v >= 2, "received msgs >= 2")
                None -> ()
            }

            // Mailbox correctly tracked dropped messages due to full capacity (dropOld strategy)
            match stats["mailbox_drops_total_full_old"] {
                Some(v) -> assertTrue(v > 0, "has old drops")
                None -> ()
            }

            // Selective receive correctly incremented depth and skipped counters
            match stats["mailbox_selective_scan_depth_total"] {
                Some(v) -> assertTrue(v > 0, "selective depth > 0")
                None -> ()
            }
            match stats["mailbox_skipped_messages"] {
                Some(v) -> assertTrue(v > 0, "skipped msgs > 0")
                None -> ()
            }

            // Block duration is 0 as expected for dropOld strategy
            match stats["mailbox_block_duration_ms_total"] {
                Some(v) -> assertEquals(0, v)
                None -> ()
            }
        }
        Fail(e) -> ()
    }
})
