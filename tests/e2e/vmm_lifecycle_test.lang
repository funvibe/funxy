testRun("lifecycle: stop timeout on onTerminate hang returns Fail and cleans VM", \ -> {
    ensureSupervisorApi()
    res = spawnVM("./tests/e2e/vmm_worker_terminate_hang.lang", { name: "lc_terminate_hang", capabilities: ["lib/time"] })
    assertOk(res)

    match res {
        Ok(id) -> {
            stopRes = stopVM(id, Some({ saveState: true, timeoutMs: 100 }))
            match stopRes {
                Ok(_) -> assertTrue(false, "stopVM should fail on graceful timeout")
                Fail(e) -> assertTrue(e != "", "timeout path should return error")
            }

            evt = waitLifecycleEventByVmId(id)
            if evt.type == "timeout" {
                assertTrue(false, "expected lifecycle event even on graceful timeout")
            } else {
                assertEquals("exit", evt.type)
                assertEquals("stopped", evt.status)
                assertEquals(id, evt.vmId)
            }

            assertEquals(false, contains(listVMs(), id))
        }
        Fail(_) -> ()
    }
})

testRun("lifecycle: limit exceeded emits vm_exit with vmId and reason", \ -> {
    ensureSupervisorApi()
    res = spawnVM("./tests/e2e/vmm_worker_gas_limit.lang", { name: "lc_limit_worker", limits: { maxInstructions: 10000 } })
    assertOk(res)

    match res {
        Ok(id) -> {
            evt = waitLifecycleEventByVmId(id)
            if evt.type == "timeout" {
                assertTrue(false, "expected vm_exit event for limit exceeded")
            } else {
                assertEquals("vm_exit", evt.type)
                assertEquals("limit_exceeded", evt.reason)
                assertEquals("crashed", evt.status)
                assertEquals(id, evt.vmId)
            }
            assertEquals(false, contains(listVMs(), id))
        }
        Fail(_) -> ()
    }
})
