import "lib/mailbox" (peek, receive)
import "lib/time" (sleepMs, clockMs)
import "lib/vmm" (setState)

fun waitPeek(deadlineMs) {
    p = peek()
    match p {
        Ok(_) -> p
        Fail(_) -> {
            if clockMs() >= deadlineMs {
                p
            } else {
                sleepMs(20)
                waitPeek(deadlineMs)
            }
        }
    }
}

deadline = clockMs() + 2000
p = waitPeek(deadline)
r = receive()

match p {
    Ok(pm) -> match r {
        Ok(rm) -> {
            if show(pm.payload) == show(rm.payload) { 
                setState("correct") 
            } else { 
                setState("mismatch: " ++ show(pm.payload) ++ " vs " ++ show(rm.payload)) 
            }
        }
        Fail(e) -> setState("receive failed: " ++ e)
    }
    Fail(e) -> setState("peek failed: " ++ e)
}

for true { sleepMs(100) }
