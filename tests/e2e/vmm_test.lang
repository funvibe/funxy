import "lib/test" (testRun, assertEquals, assertOk, testSpawnVM, assertTrue)
import "lib/vmm" (listVMs, killVM, receiveEventWait, stopVM, spawnVM)
import "lib/time" (sleepMs, clockMs)
import "lib/rpc" (callWait)
import "lib/list" (contains)

fun lifecycleEventVmId(evt) {
    if evt.type == "exit" || evt.type == "crash" || evt.type == "vm_exit" {
        evt.vmId
    } else {
        ""
    }
}

fun waitLifecycleEventByVmId(id) {
    evt = receiveEventWait(1500)
    if evt.type == "timeout" {
        evt
    } else if lifecycleEventVmId(evt) == id {
        evt
    } else {
        waitLifecycleEventByVmId(id)
    }
}

testRun("receiveEventWait timeout with explicit timeoutMs", \ -> {
    bootRes = testSpawnVM("./tests/e2e/vmm_worker_dummy.lang", { name: "timeout_bootstrap_1", capabilities: ["lib/time"] })
    assertOk(bootRes)
    match bootRes {
        Ok(id) -> {
            killVM(id)
            _ = receiveEventWait(1000) // drain expected exit event
        }
        Fail(_) -> ()
    }

    started = clockMs()
    evt = receiveEventWait(120)
    elapsed = clockMs() - started

    assertEquals("timeout", evt.type)
    assertEquals(true, evt.timed_out)
    assertTrue(elapsed < 2000, "custom timeout should not block too long")
})

testRun("Lifecycle status and cleanup on hard kill", \ -> {
    res = spawnVM("./tests/e2e/vmm_worker_dummy.lang", { name: "lifecycle_kill_worker", capabilities: ["lib/time"] })
    assertOk(res)

    match res {
        Ok(id) -> {
            killVM(id)
            evt = waitLifecycleEventByVmId(id)
            if evt.type == "timeout" {
                assertTrue(false, "expected exit/crash event for hard kill")
            } else {
                assertEquals("crashed", evt.status)
            }

            vmsAfter = listVMs()
            assertEquals(false, contains(vmsAfter, id))
        }
        Fail(_) -> ()
    }
})

testRun("Lifecycle status and cleanup on stopVM", \ -> {
    res = spawnVM("./tests/e2e/vmm_worker_dummy.lang", { name: "lifecycle_stop_worker", capabilities: ["lib/time"] })
    assertOk(res)

    match res {
        Ok(id) -> {
            stopRes = stopVM(id, Some({ saveState: true, timeoutMs: 2000 }))
            assertOk(stopRes)

            evt = waitLifecycleEventByVmId(id)
            assertEquals("exit", evt.type)
            assertEquals("stopped", evt.status)

            vmsAfter = listVMs()
            assertEquals(false, contains(vmsAfter, id))
        }
        Fail(_) -> ()
    }
})

