testRun("receiveEventWait exposes monotonic seq watermark", \ -> {
    bootRes = testSpawnVM("./tests/e2e/vmm_worker_dummy.lang", { name: "seq_bootstrap", capabilities: ["lib/time"] })
    assertOk(bootRes)
    match bootRes {
        Ok(id) -> {
            killVM(id)
            _ = receiveEventWait(1000)
        }
        Fail(_) -> ()
    }

    firstRes = spawnVM("./tests/e2e/vmm_worker_dummy.lang", { name: "seq_worker_1", capabilities: ["lib/time"] })
    assertOk(firstRes)
    secondRes = spawnVM("./tests/e2e/vmm_worker_dummy.lang", { name: "seq_worker_2", capabilities: ["lib/time"] })
    assertOk(secondRes)

    match firstRes {
        Ok(id1) -> {
            match secondRes {
                Ok(id2) -> {
                    killVM(id1)
                    evt1 = waitLifecycleEventByVmId(id1)
                    killVM(id2)
                    evt2 = waitLifecycleEventByVmId(id2)

                    assertTrue(evt1.seq > 0, "first lifecycle event should include seq watermark")
                    assertTrue(evt2.seq > evt1.seq, "seq watermark should be monotonic increasing")
                }
                Fail(_) -> ()
            }
        }
        Fail(_) -> ()
    }
})

testRun("Basic Spawn and Lifecycle", \ -> {
    config = { name: "worker_dummy", capabilities: ["lib/time"] }
    spawnRes = testSpawnVM("./tests/e2e/vmm_worker_dummy.lang", config)
    assertOk(spawnRes)
    
    match spawnRes {
        Ok(id) -> {
            vms = listVMs()
            assertTrue(len(vms) > 0, "should have VMs running")
            
            killVM(id)
            
            event = receiveEventWait()
            assertEquals("exit", event.type)
            assertEquals(id, event.vmId)
        }
        Fail(e) -> ()
    }
})

testRun("State Handoff (Hot Reload)", \ -> {
    config = { name: "stateful_worker", capabilities: ["lib/vmm", "lib/time"] }
    
    // Initial spawn
    spawnRes1 = testSpawnVM("./tests/e2e/vmm_worker_state.lang", config)
    assertOk(spawnRes1)
    
    match spawnRes1 {
        Ok(id) -> {
            sleepMs(500) // allow worker to init and set state
            
            stopRes = stopVM(id, Some({ saveState: true, timeoutMs: 2000 }))
            assertOk(stopRes)
            
            match stopRes {
                Ok(state) -> {
                    assertEquals(1, state.count)
                    
                    // Respawn with captured state using regular spawnVM because testSpawnVM lacks 3rd arg
                    spawnRes2 = spawnVM("./tests/e2e/vmm_worker_state.lang", { name: "stateful_worker_2", capabilities: ["lib/vmm", "lib/time"] }, Some(state))
                    assertOk(spawnRes2)
                    
                    match spawnRes2 {
                        Ok(id2) -> {
                            sleepMs(500)
                            stopRes2 = stopVM(id2, Some({ saveState: true, timeoutMs: 2000 }))
                            assertOk(stopRes2)
                            match stopRes2 {
                                Ok(state2) -> assertEquals(2, state2.count)
                                Fail(e) -> ()
                            }
                            // testSpawnVM tracks VMs for us, but since we used spawnVM here, stopVM already killed it.
                        }
                        Fail(e) -> ()
                    }
                }
                Fail(e) -> ()
            }
        }
        Fail(e) -> ()
    }
})

testRun("RPC Call Between VMs", \ -> {
    config = { name: "rpc_server", capabilities: ["lib/time"] }
    spawnRes = testSpawnVM("./tests/e2e/vmm_worker_rpc.lang", config)
    assertOk(spawnRes)
    
    match spawnRes {
        Ok(id) -> {
            sleepMs(500) // wait for init
            
            res = callWait(id, "ping", "hello", 1000)
            assertOk(res)
            
            match res {
                Ok(v) -> assertEquals("pong: hello", v)
                Fail(e) -> ()
            }
            
            killVM(id)
        }
        Fail(e) -> ()
    }
})

fun waitLimitEvent(id) {
    evt = receiveEventWait()
    print("waitLimitEvent got: " ++ show(evt))
    if evt.type == "vm_exit" && evt.vmId == id {
        evt
    } else {
        waitLimitEvent(id)
    }
}

